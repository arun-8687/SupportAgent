# =============================================================================
# Autonomous App Support AI Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# -----------------------------------------------------------------------------
# Azure OpenAI Configuration
# -----------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# -----------------------------------------------------------------------------
# PostgreSQL Database (with pgvector)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:<your-password>@localhost:5432/support_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# Azure Service Bus (Incident Events)
# -----------------------------------------------------------------------------
SERVICEBUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=...
SERVICEBUS_QUEUE_NAME=job-failures
SERVICEBUS_TOPIC_NAME=incident-updates

# -----------------------------------------------------------------------------
# Azure Application Insights
# -----------------------------------------------------------------------------
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
APPINSIGHTS_APP_ID=your-app-id
APPINSIGHTS_API_KEY=your-api-key

# -----------------------------------------------------------------------------
# Azure Log Analytics
# -----------------------------------------------------------------------------
LOG_ANALYTICS_WORKSPACE_ID=your-workspace-id
LOG_ANALYTICS_CLIENT_ID=your-client-id
LOG_ANALYTICS_CLIENT_SECRET=your-client-secret
LOG_ANALYTICS_TENANT_ID=your-tenant-id

# -----------------------------------------------------------------------------
# Databricks Configuration
# -----------------------------------------------------------------------------
DATABRICKS_HOST=https://adb-xxxxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi...

# -----------------------------------------------------------------------------
# SQL Server Connections (App/Metadata DBs)
# -----------------------------------------------------------------------------
SQLSERVER_APP_CONNECTION_STRING=Driver={ODBC Driver 17 for SQL Server};Server=...
SQLSERVER_METADATA_CONNECTION_STRING=Driver={ODBC Driver 17 for SQL Server};Server=...

# -----------------------------------------------------------------------------
# ITSM Integration (ServiceNow / Custom ITSM)
# -----------------------------------------------------------------------------
ITSM_BASE_URL=https://your-instance.service-now.com
ITSM_USERNAME=api_user
ITSM_PASSWORD=
ITSM_CLIENT_ID=
ITSM_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# LangSmith Observability
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=support-agent

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO

# AI Intelligence Settings
DEDUP_SIMILARITY_THRESHOLD=0.85
DEDUP_TIME_WINDOW_MINUTES=15
EVENT_STORM_THRESHOLD=10
CORRELATION_TIME_WINDOW_MINUTES=30

# Automation Settings
AUTO_FIX_ENABLED=true
AUTO_FIX_CONFIDENCE_THRESHOLD=0.9
MAX_RETRY_ATTEMPTS=3
APPROVAL_TIMEOUT_MINUTES=30

# Severity Thresholds
SEVERITY_P1_THRESHOLD=70
SEVERITY_P2_THRESHOLD=50
SEVERITY_P3_THRESHOLD=30
