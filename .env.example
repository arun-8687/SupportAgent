# Environment variables template for Support Agent
# Copy this file to .env and fill in the values

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/supportagent

# =============================================================================
# AZURE OPENAI (Required)
# =============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-5.1-codex
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2025-11-13

# =============================================================================
# AZURE AI SEARCH (Required for hybrid search)
# =============================================================================
AZURE_AI_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_AI_SEARCH_KEY=your-search-key-here
AZURE_AI_SEARCH_INDEX=support-agent-knowledge

# =============================================================================
# DATABRICKS (Optional - for Databricks job management)
# =============================================================================
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-databricks-token-here

# =============================================================================
# SQL SERVER / AZURE SQL (Optional - for SQL Server remediation)
# =============================================================================
# Option 1: Connection string
# SQL_SERVER_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=your-server.database.windows.net;Database=yourdb;Uid=<your-username>;Encrypt=yes;
# Note: Use Managed Identity or Azure Key Vault for authentication instead of embedding credentials in the connection string.

# Option 2: Individual settings
SQL_SERVER_HOST=your-server.database.windows.net
SQL_SERVER_DATABASE=yourdb
SQL_SERVER_USER=your-username
SQL_SERVER_PASSWORD=
SQL_SERVER_DRIVER=ODBC Driver 18 for SQL Server

# =============================================================================
# LANGSMITH (Optional but recommended for observability)
# =============================================================================
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=support-agent
LANGCHAIN_TRACING_V2=true

# =============================================================================
# API SECURITY
# =============================================================================
# Comma-separated list of valid API keys
API_KEYS=your-api-key-1,your-api-key-2

# =============================================================================
# SERVICE BUS (Optional - for Azure integration)
# =============================================================================
# AZURE_SERVICEBUS_CONNECTION_STRING=your-connection-string
# AZURE_SERVICEBUS_QUEUE_NAME=incident-queue
